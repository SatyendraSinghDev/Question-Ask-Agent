# ─────────────────────────────────────────────────────────────
# TestASK AI — Frontend environment (Vite)
# Copy to `.env` and edit values.
# Only VITE_* vars are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Base URL of the backend API (used by axios + RTK Query).
# In dev, point at the local server; in Docker use the nginx-proxied path.
VITE_API_BASE_URL=http://localhost:5000/api/v1

# App metadata
VITE_APP_NAME=TestASK AI
VITE_APP_TAGLINE=Intelligent Assessment Platform
