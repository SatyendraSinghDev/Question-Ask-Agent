# ─────────────────────────────────────────────────────────────
# TestASK AI — Backend Production Environment
# Copy to `.env` and fill in actual values for production.
# KEEP THIS FILE SECURE — NEVER COMMIT SENSITIVE VALUES.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=production
PORT=5000
APP_URL=https://yourdomain.com

# Database (use MongoDB Atlas for production)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/testask?retryWrites=true&w=majority

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=generate_long_random_hex_string_48_bytes_minimum
JWT_REFRESH_SECRET=generate_different_long_random_hex_string_48_bytes_minimum
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — set to your frontend domain(s)
CORS_ORIGIN=https://yourdomain.com,https://app.yourdomain.com

# AI provider — 'openai' (paid) or 'gemini' (free tier)
AI_PROVIDER=gemini

# OpenAI (paid) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-actual-api-key
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (FREE tier — recommended)
GEMINI_API_KEY=your-actual-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Email (SMTP) — for verification & password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="TestASK AI <noreply@yourdomain.com>"

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=25

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
