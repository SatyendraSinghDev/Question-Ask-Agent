# ─────────────────────────────────────────────────────────────
# TestASK AI — Backend environment
# Copy to `.env` and edit values.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/testask
# For Docker Compose Mongo with auth:
# MONGODB_URI=mongodb://testask:testask_secret@localhost:27017/testask?authSource=admin

# JWT (generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=replace_with_long_random_hex_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# AI provider — 'openai' (paid) or 'gemini' (free tier, no credit card needed).
# If omitted, auto-selects whichever API key is configured below.
AI_PROVIDER=gemini

# OpenAI (paid) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (FREE tier — recommended for local dev / no credit card)
# Get a key: https://aistudio.google.com/apikey
# Free limits (gemini-2.0-flash): 15 req/min, 1500 req/day
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Email (SMTP) — optional; needed for verification & reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="TestASK AI <no-reply@testask.ai>"

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=25

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
